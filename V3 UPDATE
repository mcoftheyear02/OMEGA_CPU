class MPhase(Enum):
    M0_NVME_READ = 0
    M1_GPU_DECOMPRESS = 1
    M2_L4_TO_CPU = 2
    M3_CPU_COMPUTE = 3

class PCIeDoubleLinkCache:
    def __init__(self):
        self.link_a_busy = False  # NVMe -> GPU_L4
        self.link_b_busy = False  # GPU_L4 -> CPU
        self.pcie_state = "WAIT"
        self.effective_gbps = 15.75 * 0.80 # ~12.6 GB/s réaliste
        self.m_phase = MPhase.M0_NVME_READ
        self.lock = threading.Lock()
        logger.info("🔧 [BIOS] Calibration FCLK 1:1. PCIe x16 prêt à passer de WAIT -> ACTIVE")

    def wake_and_transfer(self, size_bytes: int, direction: str) -> float:
        with self.lock:
            if self.pcie_state == "WAIT":
                self.pcie_state = "ACTIVE_GEN4_X16"
                logger.info("⚡ [BIOS] Liens PCIe x16 réveillés. Exclusion mutuelle active.")
            
            # RÈGLE ABSOLUE : PAS LES DEUX LINK SIMULTANÉMENT
            if direction == "A" and self.link_b_busy:
                time.sleep(0.001) # Attente active pour éviter le goulot d'étranglement
            elif direction == "B" and self.link_a_busy:
                time.sleep(0.001)
                
            if direction == "A": self.link_a_busy = True
            else: self.link_b_busy = True

        # Simulation du transfert
        elapsed_ms = (size_bytes / (self.effective_gbps * 1e9)) * 1000.0
        time.sleep(elapsed_ms / 1000.0) # Simule la latence
        
        with self.lock:
            if direction == "A": self.link_a_busy = False
            else: self.link_b_busy = False
            
        return round(elapsed_ms, 4)

