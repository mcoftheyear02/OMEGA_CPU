    def process_packet(self, payload: bytes, lane: str, metadata: Dict, signature: str, source_ip: str) -> Dict:
        # 1. Aurora
        aurora_pass, msg = self.aurora.check_access(source_ip, signature!="UNSIGNED", metadata.get('fake_balance', False))
        if not aurora_pass: return {"status": "BLOCKED", "reason": msg}
        # 2. Oberon L0
        is_valid, reason = self.shield.verify_packet(payload, lane, metadata, signature)
        if not is_valid: return {"status": "VAPORIZED", "reason": reason, "defense_level": self.shield.defense_level}
        # 3. Cortex
        cortex_res = self.cortex.ingest_and_transform(lane, metadata)
        # 4. Neural Core + PCIe Double Link
        out_bin, iter_time = self.mind.forward_pass_iso(payload)
        # 5. Security AI
        self.sec_ai.record_metric('iteration_time', iter_time)
        self.sec_ai.quant_history.append("INT8_IQ4_NL")
        anomaly = self.sec_ai.detect_anomaly('iteration_time', iter_time)
        quant_attack = self.sec_ai.detect_quantization_attack(window=10)
        
        alerts = []
        if anomaly: alerts.append(anomaly)
        if quant_attack: alerts.append(quant_attack)

        return {
            "status": "PROCESSED_ISO_FPS", "lane": lane,
            "priority": cortex_res['priority'] if cortex_res else "NONE",
            "iter_ms": round(iter_time, 4), "alerts": alerts
        }

