# 5. NEURAL CORE 16T (Ratio 0.625, INT8)
# ==============================================================================
class NeuralCore16T:
    def __init__(self, pcie_link: PCIeDoubleLinkCache):
        self.pcie_link = pcie_link
        self.executor = ThreadPoolExecutor(max_workers=MAX_CPU_THREADS, thread_name_prefix="NEURAL_16T")
        self.weights = (np.random.rand(12, 4, 4).astype(np.float32)) * GOLDEN_RATIO_STABLE
        logger.info(f"🧠 NeuralCore 16T Ready | Ratio: {GOLDEN_RATIO_STABLE} | Precision: {BINARY_PRECISION}")

    def _process_chunk(self, chunk: np.ndarray) -> np.ndarray:
        return np.round(chunk.astype(np.float32) * GOLDEN_RATIO_STABLE).astype(BINARY_PRECISION)

    def forward_pass_iso(self, binary_payload: bytes) -> Tuple[bytes, float]:
        start = time.perf_counter()
        
        # M0 & M1: NVMe -> GPU (Lien A)
        self.pcie_link.wake_and_transfer(len(binary_payload), "A")
        
        # M2: GPU -> CPU (Lien B)
        self.pcie_link.wake_and_transfer(len(binary_payload), "B")
        
        # M3: Calcul 16 Threads CPU
        data_array = np.frombuffer(binary_payload, dtype=np.uint8)
        chunk_size = max(1, len(data_array) // MAX_CPU_THREADS)
        chunks = [data_array[i:i + chunk_size] for i in range(0, len(data_array), chunk_size)]
        
        futures = [self.executor.submit(self._process_chunk, c) for c in chunks]
        final_binary = np.concatenate([f.result() for f in futures]).tobytes()
        
        return final_binary, (time.perf_counter() - start) * 1000.0

