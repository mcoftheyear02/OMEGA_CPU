import os, time, json, hmac, hashlib, math, logging, statistics, threading
import numpy as np
from queue import Queue
from concurrent.futures import ThreadPoolExecutor
from typing import Dict, List, Optional, Tuple, Any, Callable
from datetime import datetime
from collections import deque
from dataclasses import dataclass
from enum import Enum
from numba import njit

logging.basicConfig(level=logging.INFO, format="[%(asctime)s] [%(threadName)s] %(message)s")
logger = logging.getLogger("FXION_OMEGA_AIO")

class FXION_CONFIG:
    MAX_CPU_THREADS = 16
    GOLDEN_RATIO_STABLE = np.float32(0.625)
    FIBONACCI_EPOCH = 4272
    SECURITY_BATCH_SIZE = 50
    EFFECTIVE_PCIE_GBPS = (15.75 * 0.80) * 4.0  # ~50.4 GB/s équivalent QINT2
    AURORA = {"localhost_only": True, "block_unsigned_transfer": True, "block_fake_balance": True}
    QFX_PROFILES = {
        "QINT2":  {"family": "IQ", "accuracy": 0.840, "vram_gb": 0.95, "base_tps": 214.7, "prior": 0.06},
        "IQ4_NL": {"family": "IQ", "accuracy": 0.975, "vram_gb": 2.05, "base_tps": 166.2, "prior": 0.11},
        "Q8_0":   {"family": "K",  "accuracy": 0.991, "vram_gb": 3.82, "base_tps": 128.4, "prior": 0.15}
    }

QINT2_LOOKUP = np.array([-3.0, -1.0, 1.0, 3.0], dtype=np.float32)

@njit(fastmath=True, cache=True)
def dequantize_block_jit_numba(packed_data: np.ndarray, scale: float, count: int) -> np.ndarray:
    out = np.empty(count, dtype=np.int8)
    ratio = FXION_CONFIG.GOLDEN_RATIO_STABLE
    for i in range(count):
        byte_idx = i >> 2
        shift = 6 - (i & 3) * 2
        bits_val = (packed_data[byte_idx] >> shift) & 0b11
        q_val = QINT2_LOOKUP[bits_val]
        final_val = q_val * scale * ratio
        if final_val > 127.0: out[i] = 127
        elif final_val < -128.0: out[i] = -128
        else: out[i] = np.int8(np.round(final_val))
    return out

def pack_bits_qint2_fast(bits_list: List[str]) -> bytes:
    out = bytearray()
    acc, n = 0, 0
    for b in bits_list:
        acc = (acc << 2) | int(b, 2)
        n += 2
        if n == 8:
            out.append(acc)
            acc, n = 0, 0
    if n: out.append(acc << (8 - n))
    return bytes(out)

class QFXOptimizer:
    def __init__(self):
        self.quants = list(FXION_CONFIG.QFX_PROFILES.keys())
        self.counts = {q: 0 for q in self.quants}
        self.rewards = {q: 0.0 for q in self.quants}
        self.t = 0
    def select_best_quant(self) -> str:
        self.t += 1
        for q in self.quants:
            if self.counts[q] == 0: return q
        scores = {}
        for q in self.quants:
            exploit = self.rewards[q] / self.counts[q]
            explore = math.sqrt(2 * math.log(self.t) / self.counts[q])
            vram_eff = max(0.0, 1.0 - (FXION_CONFIG.QFX_PROFILES[q]["vram_gb"] / 4.0))
            aug = FXION_CONFIG.QFX_PROFILES[q]["prior"] + (0.04 * vram_eff if FXION_CONFIG.QFX_PROFILES[q]["family"] == "IQ" else 0.0)
            scores[q] = exploit + explore + aug
        return max(scores, key=scores.__getitem__)
    def record_reward(self, quant: str, tps: float):
        acc = FXION_CONFIG.QFX_PROFILES[quant]["accuracy"]
        spd = min(tps / 200.0, 1.0)
        vram = 1.0 - (FXION_CONFIG.QFX_PROFILES[quant]["vram_gb"] / 4.0)
        reward = 0.45 * acc + 0.30 * spd + 0.25 * vram
        if quant == "QINT2": reward *= 1.10
        self.rewards[quant] += reward
        self.counts[quant] += 1

class PCIeDoubleLink:
    def __init__(self):
        self.link_a_busy = False
        self.link_b_busy = False
        self.lock = threading.Lock()
    def transfer(self, size_bytes: int, direction: str) -> float:
        with self.lock:
            if direction == "A" and self.link_b_busy: time.sleep(0.0002)
            elif direction == "B" and self.link_a_busy: time.sleep(0.0002)
            if direction == "A": self.link_a_busy = True
            else: self.link_b_busy = True
        elapsed_ms = (size_bytes / (FXION_CONFIG.EFFECTIVE_PCIE_GBPS * 1e9)) * 1000.0
        time.sleep(elapsed_ms / 1000.0)
        with self.lock:
            if direction == "A": self.link_a_busy = False
            else: self.link_b_busy = False
        return round(elapsed_ms, 4)

class NeuralCore16T:
    def __init__(self, pcie_link: PCIeDoubleLink, qfx: QFXOptimizer):
        self.pcie_link = pcie_link
        self.qfx = qfx
        self.executor = ThreadPoolExecutor(max_workers=FXION_CONFIG.MAX_CPU_THREADS, thread_name_prefix="NEURAL_16T")
    def _process_chunk_jit(self, chunk: np.ndarray, count: int, scale: float) -> np.ndarray:
        return dequantize_block_jit_numba(chunk, scale, count)
    def forward_pass(self, float_payload: List[float]) -> Tuple[np.ndarray, float, str]:
        start = time.perf_counter()
        best_quant = self.qfx.select_best_quant()
        scale = max(abs(x) for x in float_payload) / 3.0 if float_payload else 1.0
        levels = [-3, -1, 1, 3]
        bits = "".join([f"{levels.index(min(levels, key=lambda v: abs(v - round(x / scale)))):02b}" for x in float_payload])
        packed_bytes = pack_bits_qint2_fast(bits)
        self.pcie_link.transfer(len(packed_bytes), "A")
        self.pcie_link.transfer(len(packed_bytes), "B")
        count = len(float_payload)
        chunk_size = max(1, len(packed_bytes) // FXION_CONFIG.MAX_CPU_THREADS)
        chunks = [np.frombuffer(packed_bytes[i:i + chunk_size], dtype=np.uint8) for i in range(0, len(packed_bytes), chunk_size)]
        counts = [count // FXION_CONFIG.MAX_CPU_THREADS] * FXION_CONFIG.MAX_CPU_THREADS
        futures = [self.executor.submit(self._process_chunk_jit, c, cnt, scale) for c, cnt in zip(chunks, counts)]
        final_binary = np.concatenate([f.result() for f in futures]).tobytes()
        elapsed = (time.perf_counter() - start) * 1000.0
        self.qfx.record_reward(best_quant, (count / 1000.0) / (elapsed / 1000.0) if elapsed > 0 else 0.0)
        return final_binary, elapsed, best_quant

class AuroraSecurity:
    def check_access(self, source_ip: str, is_signed: bool, has_fake_balance: bool) -> Tuple[bool, str]:
        if FXION_CONFIG.AURORA["localhost_only"] and source_ip != "127.0.0.1": return False, "AURORA_BLOCK: Remote access denied"
        if FXION_CONFIG.AURORA["block_unsigned_transfer"] and not is_signed: return False, "AURORA_BLOCK: Unsigned transfer"
        if FXION_CONFIG.AURORA["block_fake_balance"] and has_fake_balance: return False, "AURORA_BLOCK: Fake balance"
        return True, "AURORA_PASS"

class NeutrinoSpinKeyRotator:
    def __init__(self):
        self.base_seed = b"OBERON_MIND_EX"
        self.rotation_interval_ms = 1
        self._current_key = None
        self._key_timestamp = 0
    def get_current_key(self) -> bytes:
        current_time_ms = int(time.time() * 1000)
        if (current_time_ms - self._key_timestamp) >= self.rotation_interval_ms:
            entropy = (current_time_ms ^ int.from_bytes(os.urandom(8), 'big')).to_bytes(8, 'big')
            self._current_key = hashlib.sha3_512(self.base_seed + entropy + str(current_time_ms).encode()).digest()
            self._key_timestamp = current_time_ms
        return self._current_key
    def get_key_id(self) -> str:
        return hashlib.sha256(self.get_current_key()).hexdigest()[:16]

class HMACOberonShield:
    def __init__(self):
        self.key_rotator = NeutrinoSpinKeyRotator()
        self.vaporized_count = 0
        self.validated_count = 0
        self.defense_level = 0
    def sign_packet(self, payload: bytes, lane: str, metadata: Dict) -> str:
        key = self.key_rotator.get_current_key()
        msg = b'|'.join([lane.encode(), str(metadata.get('timestamp', time.time())).encode(), payload])
        return f"{self.key_rotator.get_key_id()}:{hmac.new(key, msg, hashlib.sha3_512).hexdigest()}"
    def verify_packet(self, payload: bytes, lane: str, metadata: Dict, signature: str) -> Tuple[bool, str]:
        try: key_id, provided_sig = signature.split(':', 1)
        except ValueError:
            self.vaporized_count += 1
            return False, "Malformed signature"
        key = self.key_rotator.get_current_key()
        msg = b'|'.join([lane.encode(), str(metadata.get('timestamp', time.time())).encode(), payload])
        if hmac.compare_digest(hmac.new(key, msg, hashlib.sha3_512).hexdigest(), provided_sig):
            self.validated_count += 1
            return True, "HMAC_VALID"
        self.vaporized_count += 1
        self.defense_level = min(self.defense_level + 1, 5)
        return False, f"HMAC_MISMATCH_DEFENSE_LEVEL_{self.defense_level}"

class AsyncSecurityAI:
    def __init__(self):
        self.alerts: List[Dict] = []
        self.metrics_history = {'iteration_time': deque(maxlen=100)}
        self.baseline_stats = {}
        self.anomaly_threshold = 2.5
        self.alert_queue = Queue()
        self.batch_counter = 0
        self.running = True
        self.writer_thread = threading.Thread(target=self._background_writer, daemon=True, name="SEC_AI_WRITER")
        self.writer_thread.start()
    def _background_writer(self):
        while self.running:
            try:
                alert = self.alert_queue.get(timeout=2.0)
                self.alerts.append(alert)
                self.batch_counter += 1
                if self.batch_counter >= FXION_CONFIG.SECURITY_BATCH_SIZE:
                    self._save_state()
                    self.batch_counter = 0
                self.alert_queue.task_done()
            except Exception:
                if self.batch_counter > 0: self._save_state(); self.batch_counter = 0
    def _save_state(self):
        try:
            data = {'alerts': self.alerts[-100:], 'baseline_stats': self.baseline_stats, 'last_update': datetime.now().isoformat()}
            os.makedirs(os.path.dirname('/tmp/fxion_security.json'), exist_ok=True)
            with open('/tmp/fxion_security.json', 'w') as f: json.dump(data, f, indent=2)
        except Exception: pass
    def record_metric(self, metric_name: str, value: float):
        if metric_name in self.metrics_history:
            self.metrics_history[metric_name].append(value)
            if len(self.metrics_history[metric_name]) >= 10:
                vals = list(self.metrics_history[metric_name])
                self.baseline_stats[metric_name] = {'mean': statistics.mean(vals), 'stdev': statistics.stdev(vals) if len(vals) > 1 else 0}
    def detect_anomaly(self, metric_name: str, value: float) -> Optional[Dict]:
        if metric_name not in self.baseline_stats or self.baseline_stats[metric_name]['stdev'] == 0: return None
        bl = self.baseline_stats[metric_name]
        z_score = abs(value - bl['mean']) / bl['stdev']
        if z_score > self.anomaly_threshold:
            alert = {'type': 'anomaly', 'metric': metric_name, 'z_score': round(z_score, 2), 'severity': 'high' if z_score > 4 else 'medium'}
            self.alert_queue.put(alert)
            return alert
        return None
    def stop(self):
        self.running = False
        self.writer_thread.join(timeout=1.0)
        if self.batch_counter > 0: self._save_state()

class CortexA72Bridge:
    def __init__(self):
        self.logic_layer_callback: Optional[Callable] = None
    def connect_logic_layer(self, callback: Callable): self.logic_layer_callback = callback
    def ingest_and_transform(self, source: str, data: Dict) -> Optional[Dict]:
        transformed = data.copy()
        if 'ra' in data and 'dec' in data:
            transformed['elliptical_x'] = data['ra'] * (1.0 - 0.85 * (data['dec'] / 90.0)**2)
        if 'intensity' in data:
            transformed['seismic_wave'] = data['intensity'] * 0.02
            transformed['is_critical'] = abs(transformed['seismic_wave']) > 0.5
        priority = 'CRITICAL' if transformed.get('is_critical') else 'NORMAL'
        if priority != 'NOISE' and self.logic_layer_callback:
            self.logic_layer_callback({"type": "IQ_DIRECT_CPU", "source": source, "priority": priority})
        return {"priority": priority, "data": transformed}

class LoneRoadPipeline:
    def __init__(self, mind: NeuralCore16T, shield: HMACOberonShield, sec_ai: AsyncSecurityAI, aurora: AuroraSecurity, cortex: CortexA72Bridge):
        self.mind, self.shield, self.sec_ai, self.aurora, self.cortex = mind, shield, sec_ai, aurora, cortex
    def process_packet(self, float_data: List[float], lane: str, metadata: Dict, signature: str, source_ip: str) -> Dict:
        aurora_pass, msg = self.aurora.check_access(source_ip, signature!="UNSIGNED", metadata.get('fake_balance', False))
        if not aurora_pass: return {"status": "BLOCKED", "reason": msg}
        payload_bytes = json.dumps(float_data).encode()
        is_valid, reason = self.shield.verify_packet(payload_bytes, lane, metadata, signature)
        if not is_valid: return {"status": "VAPORIZED", "reason": reason, "defense_level": self.shield.defense_level}
        out_int8, iter_time, chosen_quant = self.mind.forward_pass(float_data)
        self.sec_ai.record_metric('iteration_time', iter_time)
        anomaly = self.sec_ai.detect_anomaly('iteration_time', iter_time)
        return {
            "status": "PROCESSED_ISO_FPS_AIO", "lane": lane, "chosen_quant": chosen_quant,
            "priority": self.cortex.ingest_and_transform(lane, metadata)['priority'],
            "iter_ms": round(iter_time, 4), "alerts": [anomaly] if anomaly else []
        }

