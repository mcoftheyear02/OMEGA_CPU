def create_github_zip():
    zip_filename = "FXION_OMEGA_GITHUB_READY.zip"
    project_root = "FXION_OMEGA"
    
    print(f"🚀 Création de l'archive {zip_filename}...")
    
    with zipfile.ZipFile(zip_filename, 'w', zipfile.ZIP_DEFLATED) as zipf:
        for filepath, content in PROJECT_FILES.items():
            full_path = os.path.join(project_root, filepath)
            print(f"  📄 Ajout de : {full_path}")
            zipf.writestr(full_path, content)
            
    print(f"\n✅ SUCCÈS ! Le fichier '{zip_filename}' a été créé dans le répertoire courant.")
    print("📌 Pour l'uploader sur GitHub :")
