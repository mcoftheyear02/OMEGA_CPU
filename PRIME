class SplitL4WayLinkManager:
    def __init__(self, total_capacity_mb: float = PRIME_CONFIG.VRAM_LIMIT_GB * 1024):
        self.half_capacity_bytes = int((total_capacity_mb / 2.0) * 1024 * 1024)
        self.vram_used_bytes = 0
        self.buffer_ccx0 = np.empty(self.half_capacity_bytes, dtype=np.uint8)
        self.buffer_ccx1 = np.empty(self.half_capacity_bytes, dtype=np.uint8)
        print(f"  [SPLIT L4] Initialisé: 2x {self.half_capacity_bytes/1024/1024:.0f}MB | 105A Stable: {PRIME_CONFIG.VRAM_TDC_105A_STABLE}")

    def stage_nvme_burst(self, packed_data: bytes) -> float:
        half_size = len(packed_data) // 2
        self.vram_used_bytes += len(packed_data)
        start = time.perf_counter()
        # Simulation du burst séquentiel à 7 Go/s (le NVMe adore ça, zéro contention IOPS)
        time.sleep((half_size / (PRIME_CONFIG.NVME_SEQ_GBPS * 1e9)))
        # Zero-copy assignment (simulation du DMA vers les tampons L4)
        self.buffer_ccx0[:half_size] = np.frombuffer(packed_data[:half_size], dtype=np.uint8)
        self.buffer_ccx1[:half_size] = np.frombuffer(packed_data[half_size:], dtype=np.uint8)
        return (time.perf_counter() - start) * 1000.0

    def get_ccx_view(self, ccx_id: int, offset: int, size: int) -> np.ndarray:
        return self.buffer_ccx0[offset:offset+size] if ccx_id == 0 else self.buffer_ccx1[offset:offset+size]

