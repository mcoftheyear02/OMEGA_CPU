# 4. MOTEUR PHANTOM JIT (KERNEL FUSION 1-CYCLE : Le Cœur de la Vitesse)
# ==============================================================================
@njit(fastmath=True, cache=True, parallel=True)
def prime_fused_dequantize(packed_data: np.ndarray, scale: float, out: np.ndarray, xor_key: np.uint8):
    """
    FUSION TOTALE : Décode QINT2, applique le XOR de sécurité, et le ratio 0.625 
    dans une SEULE boucle vectorisée. ZÉRO overhead. ZÉRO accès mémoire superflu.
    """
    count = len(out)
    mask = xor_key & 0b11  # On n'applique le XOR que sur les 2 bits de données
    scalar = np.float32(PRIME_CONFIG.GOLDEN_RATIO * PRIME_CONFIG.PBO_SCALAR_MULTIPLIER)
    
    for i in prange(count):
        byte_idx = i >> 2
        shift = 6 - (i & 3) * 2
        
        # 1. Extraction des 2 bits bruts
        bits = (packed_data[byte_idx] >> shift) & 0b11
        
        # 2. PHANTOM LAYER : Dé-obfuscation XOR (Cycle CPU unique)
        unmasked_bits = bits ^ mask
        
        # 3. Conversion mathématique pure : 0,1,2,3 -> -3,-1,1,3
        q_val = np.float32((unmasked_bits * 2) - 3)
        
        # 4. Application des multiplicateurs (Golden Ratio + PBO Scalar)
        out[i] = q_val * scale * scalar

