class QFXOptimizer:
    def __init__(self):
        self.quants = list(PRIME_CONFIG.QUANT_PROFILES.keys())
        self.counts = {q: 0 for q in self.quants}
        self.rewards = {q: 0.0 for q in self.quants}
        self.t = 0
    def select_best_quant(self) -> str:
        self.t += 1
        for q in self.quants:
            if self.counts[q] == 0: return q
        scores = {}
        for q in self.quants:
            exploit = self.rewards[q] / self.counts[q]
            explore = math.sqrt(2 * math.log(self.t) / self.counts[q])
            vram_eff = max(0.0, 1.0 - (PRIME_CONFIG.QUANT_PROFILES[q]["vram_gb"] / 4.0))
            aug = PRIME_CONFIG.QUANT_PROFILES[q]["prior"] + (0.04 * vram_eff if PRIME_CONFIG.QUANT_PROFILES[q]["family"] == "IQ" else 0.0)
            scores[q] = exploit + explore + aug
        return max(scores, key=scores.__getitem__)
    def record_reward(self, quant: str, tps: float):
        acc = PRIME_CONFIG.QUANT_PROFILES[quant]["accuracy"]
        spd = min(tps / 200.0, 1.0)
        vram = 1.0 - (PRIME_CONFIG.QUANT_PROFILES[quant]["vram_gb"] / 4.0)
        reward = 0.45 * acc + 0.30 * spd + 0.25 * vram
        if PRIME_CONFIG.QUANT_PROFILES[quant]["family"] == "IQ": reward *= 1.10
        self.rewards[quant] += reward
        self.counts[quant] += 1

