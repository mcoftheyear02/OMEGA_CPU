# 2. ADAPTIVE CACHE CORE (Le Cœur de l'Optimisation Non-Bottleneck)
# ==============================================================================
@dataclass
class CacheRouteStats:
    target_level: str       # 'L1_REG', 'L2_CACHE', 'L3_SHARED', 'NVME_SPLIT'
    size_bytes: int
    elapsed_ms: float
    bandwidth_gbps: float
    is_bottleneck: bool

class AdaptiveCacheCore:
    """
    Évalue et choisit la voie de cache la plus rapide à CHAQUE cycle.
    Évite les goulots d'étranglement en basculant dynamiquement entre L1, L2, L3 et NVMe.
    """
    def __init__(self):
        # Vitesses théoriques CPU modernes (GB/s)
        self.speeds = {'L1_REG': 100.0, 'L2_CACHE': 50.0, 'L3_SHARED': 20.0, 'NVME_SPLIT': 7.0}
        self.capacities = {'L1_REG': 32, 'L2_CACHE': 512, 'L3_SHARED': 32768, 'NVME_SPLIT': 1048576} # en KB
        
        # Historique des performances par niveau pour détecter les goulots d'étranglement
        self.latency_history: Dict[str, deque] = {level: deque(maxlen=10) for level in self.speeds}
        self.current_load = {level: 0.0 for level in self.speeds} # 0.0 à 1.0

    def evaluate_and_route(self, size_bytes: int, thread_id: int) -> CacheRouteStats:
        """Décide de la meilleure voie de cache pour ce cycle spécifique."""
        size_kb = size_bytes / 1024
        
        # 1. Filtrage par capacité
        viable_routes = [lvl for lvl, cap in self.capacities.items() if size_kb <= cap]
        if not viable_routes:
            viable_routes = ['NVME_SPLIT'] # Fallback ultime

        # 2. Calcul du score de vitesse pour chaque voie viable (plus le score est bas, mieux c'est)
        best_route = viable_routes[0]
        best_score = float('inf')

        for route in viable_routes:
            # Pénalité de congestion : si la charge est > 0.8, on pénalise fortement cette voie
            congestion_penalty = 1.0 + (self.current_load[route] * 5.0)
            
            # Score = (Taille / Vitesse) * Pénalité
            estimated_time_ms = (size_bytes / (self.speeds[route] * 1e9)) * 1000.0 * congestion_penalty
            
            if estimated_time_ms < best_score:
                best_score = estimated_time_ms
                best_route = route

        # 3. Simulation du transfert et mise à jour des métriques
        start = time.perf_counter()
        # Simulation d'un accès mémoire (np.ascontiguousarray force l'alignement cache)
        _ = np.ascontiguousarray(np.zeros(size_bytes, dtype=np.uint8))
        elapsed_ms = (time.perf_counter() - start) * 1000.0
        
        # Mise à jour de l'historique et de la charge
        self.latency_history[best_route].append(elapsed_ms)
        avg_latency = statistics.mean(self.latency_history[best_route])
        
        # Détection de goulot d'étranglement : si la latence actuelle est > 2x la moyenne
        is_bottleneck = elapsed_ms > (avg_latency * 2.0) if len(self.latency_history[best_route]) > 3 else False
        
        if is_bottleneck:
            self.current_load[best_route] = min(1.0, self.current_load[best_route] + 0.3) # Augmente la pénalité pour le prochain cycle
        else:
            self.current_load[best_route] = max(0.0, self.current_load[best_route] - 0.1) # Relâche la pression

        effective_bw = (size_bytes / 1e9) / (elapsed_ms / 1000.0) if elapsed_ms > 0 else 0.0

        return CacheRouteStats(
            target_level=best_route,
            size_bytes=size_bytes,
            elapsed_ms=round(elapsed_ms, 4),
            bandwidth_gbps=round(effective_bw, 2),
            is_bottleneck=is_bottleneck
        )

