# 3. NEURAL CORE CPU (16 Threads, INT8, Ratio 0.625)
# ==============================================================================
class NeuralCoreCPU:
    def __init__(self, cache_core: AdaptiveCacheCore):
        self.cache_core = cache_core
        self.executor = ThreadPoolExecutor(max_workers=MAX_CPU_THREADS, thread_name_prefix="NEURAL_16T")
        self.weights = (np.random.rand(12, 4, 4).astype(np.float32)) * GOLDEN_RATIO_STABLE
        logger.info(f"NeuralCoreCPU init | Threads: {MAX_CPU_THREADS} | Ratio: {GOLDEN_RATIO_STABLE} | Cache: ADAPTIVE")

    def _process_chunk(self, chunk: np.ndarray, thread_id: int) -> Tuple[np.ndarray, CacheRouteStats]:
        # 1. Décision de cache adaptative AVANT le calcul
        route_stats = self.cache_core.evaluate_and_route(chunk.nbytes, thread_id)
        
        # 2. Calcul neuronal binaire/INT8 avec ratio 0.625
        processed = np.round(chunk.astype(np.float32) * GOLDEN_RATIO_STABLE).astype(BINARY_PRECISION)
        return processed, route_stats

    def forward_pass_adaptive(self, binary_payload: bytes) -> Tuple[bytes, float, List[CacheRouteStats]]:
        start = time.perf_counter()
        data_array = np.frombuffer(binary_payload, dtype=np.uint8)
        
        # Découpage pour les 16 threads
        chunk_size = max(1, len(data_array) // MAX_CPU_THREADS)
        chunks = [data_array[i:i + chunk_size] for i in range(0, len(data_array), chunk_size)]
        
        # Exécution parallèle avec récupération des stats de cache
        futures = [self.executor.submit(self._process_chunk, c, i) for i, c in enumerate(chunks)]
        results = [f.result() for f in futures]
        
        processed_chunks = [r[0] for r in results]
        cache_stats = [r[1] for r in results]
        
        final_binary = np.concatenate(processed_chunks).tobytes()
        elapsed = time.perf_counter() - start
        
        return final_binary, elapsed, cache_stats

